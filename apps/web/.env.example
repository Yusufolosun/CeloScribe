# ═══════════════════════════════════════════════════════════════════
# CeloScribe Frontend Environment Variables
# ═══════════════════════════════════════════════════════════════════
# This is a template. Copy to .env.local and fill in your actual values.
# NEVER commit real credentials — .env.local is in .gitignore.

# ───────────────────────────────────────────────────────────────────
# PUBLIC CONFIG (embedded in browser bundle, safe to expose)
# ───────────────────────────────────────────────────────────────────

# Deployed CeloScribe contract address on Celo mainnet
# Example: 0x1234567890abcdef1234567890abcdef12345678
NEXT_PUBLIC_CELOSCRIBE_CONTRACT_ADDRESS=

# Celo RPC endpoint (Forno is public)
# Default: https://forno.celo.org (Celo mainnet)
# For testing, use a local fork or testnet RPC
NEXT_PUBLIC_CELO_RPC_URL=https://forno.celo.org

# Thirdweb SDK client ID (required for thirdweb package)
# Get from: https://thirdweb.com/create-api-key
# Public-facing key only — does NOT contain secrets
NEXT_PUBLIC_THIRDWEB_CLIENT_ID=

# ───────────────────────────────────────────────────────────────────
# SERVER-SIDE SECRETS (never exposed to browser)
# Set in Vercel Environment Variables (Settings > Environment Variables)
# ───────────────────────────────────────────────────────────────────

# AI Provider API Keys — only server routes use these
# Used for: /api/task/*, /api/payment/* endpoints that call AI services
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=
FAL_API_KEY=

# Thirdweb Secret Key (for contract interactions from backend)
# NOT the same as NEXT_PUBLIC_THIRDWEB_CLIENT_ID
THIRDWEB_SECRET_KEY=

# ───────────────────────────────────────────────────────────────────
# OPTIONAL CONFIG
# ───────────────────────────────────────────────────────────────────

# Payment verification confirmations (default: 3 in prod, 1 in dev)
# Require N blocks before accepting a payment as final
PAYMENT_MIN_CONFIRMATIONS=3
