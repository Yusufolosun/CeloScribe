# ═══════════════════════════════════════════════════════════════════
# CeloScribe Environment Configuration
# ═══════════════════════════════════════════════════════════════════
#
# IMPORTANT: Never commit .env.local or any file containing real values.
# Copy this file to .env.local and fill in your actual values locally.
#
# For production deployments, use your platform's secret manager:
# - Vercel: Environment Variables
# - AWS: Secrets Manager
# - Azure: Key Vault
# - Docker: Secrets
#

# ═══════════════════════════════════════════════════════════════════
# BLOCKCHAIN & CONTRACT CONFIGURATION
# ═══════════════════════════════════════════════════════════════════

# RPC endpoints for blockchain interaction
# For development: Use testnet (Alfajores)
# For production: Use mainnet (Celo)
ALFAJORES_RPC_URL=https://alfajores-forno.celo-testnet.org
CELO_RPC_URL=https://forno.celo.org

# Frontend uses this RPC URL at runtime
NEXT_PUBLIC_CELO_RPC_URL=https://forno.celo.org

# Smart contract deployment
# Set after running: pnpm --dir packages/contracts deploy:mainnet
NEXT_PUBLIC_CELOSCRIBE_CONTRACT_ADDRESS=

# ═══════════════════════════════════════════════════════════════════
# SMART CONTRACT DEPLOYMENT (Mainnet only)
# ═══════════════════════════════════════════════════════════════════

# Private key of wallet that will deploy contracts
# Format: 0x... (without leading 0x is also accepted)
# ⚠️  NEVER commit this value - keep in .env.local only
DEPLOYER_PRIVATE_KEY=

# Address where cUSD payments will be collected
# This is where revenue will be withdrawn
TREASURY_ADDRESS=

# API key for contract verification on Celoscan
# Get from: https://celoscan.io/myapikey
CELOSCAN_API_KEY=

# ═══════════════════════════════════════════════════════════════════
# THIRDWEB CONFIGURATION
# ═══════════════════════════════════════════════════════════════════

# Public client ID (not a secret, but keep in environment for portability)
# Get from: https://thirdweb.com/dashboard/settings/api-keys
NEXT_PUBLIC_THIRDWEB_CLIENT_ID=

# Server-side secret (only needed if using Thirdweb backend APIs)
# ⚠️  NEVER commit this value - keep in .env.local only
THIRDWEB_SECRET_KEY=

# ═══════════════════════════════════════════════════════════════════
# AI PROVIDER CREDENTIALS
# ═══════════════════════════════════════════════════════════════════

# DeepSeek API Key (for TEXT_SHORT and TRANSLATE tasks)
# Get from: https://platform.deepseek.com/api_keys
# ⚠️  NEVER commit this value - keep in .env.local only
DEEPSEEK_API_KEY=

# Anthropic API Key (for TEXT_LONG tasks)
# Get from: https://console.anthropic.com/account/keys
# ⚠️  NEVER commit this value - keep in .env.local only
ANTHROPIC_API_KEY=

# FAL AI API Key (for IMAGE tasks)
# Get from: https://fal.ai/dashboard/keys
# ⚠️  NEVER commit this value - keep in .env.local only
FAL_API_KEY=

# ═══════════════════════════════════════════════════════════════════
# OPTIONAL: ADVANCED CONFIGURATION
# ═══════════════════════════════════════════════════════════════════

# Rate limiting configuration (seconds)
# RATE_LIMIT_WINDOW_SECONDS=3600
# RATE_LIMIT_MAX_REQUESTS_PER_WALLET=100

# Payment verification timeout (milliseconds)
# PAYMENT_VERIFICATION_TIMEOUT_MS=30000

# Logging level: debug | info | warn | error
# LOG_LEVEL=info

# ═══════════════════════════════════════════════════════════════════
# DEPLOYMENT CHECKLIST
# ═══════════════════════════════════════════════════════════════════
#
# Before deploying to production:
#
# [ ] All values above are filled in with production values
# [ ] All secrets are stored in platform secret manager
# [ ] .env.local is listed in .gitignore and NOT committed
# [ ] API keys are rotated if older than 90 days
# [ ] Contract is deployed and address set in NEXT_PUBLIC_CELOSCRIBE_CONTRACT_ADDRESS
# [ ] Contract is verified on Celoscan for transparency
# [ ] All tests pass: pnpm test
# [ ] Build succeeds: pnpm build
# [ ] Linting passes: pnpm lint
#
