{
  "name": "celoscribe",
  "private": true,
  "packageManager": "pnpm@10.28.1",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "lint-staged": {
    "apps/web/**/*.{ts,tsx}": [
      "cross-env ESLINT_USE_FLAT_CONFIG=false eslint --fix --max-warnings=0",
      "prettier --write"
    ],
    "packages/contracts/**/*.sol": [
      "prettier --write --plugin=prettier-plugin-solidity"
    ],
    "**/*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-solidity": "^2.3.1",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  }
}
